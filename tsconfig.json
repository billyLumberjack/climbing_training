{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "allowJs": true
  },
  "ts-node": {
    "esm": true,
    "experimentalEsm": true,
    "moduleTypes": {
      "**/*": "esm"
    }
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
